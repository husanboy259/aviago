# ─── App ───────────────────────────────────────────
NODE_ENV=development

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key
JWT_REFRESH_EXPIRES_IN=30d

# ─── Databases ─────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=delidrone
POSTGRES_PASSWORD=delidrone_secret
POSTGRES_DB=delidrone

AUTH_DB=delidrone_auth
USER_DB=delidrone_users
RESTAURANT_DB=delidrone_restaurants
ORDER_DB=delidrone_orders
DRONE_DB=delidrone_drones
PAYMENT_DB=delidrone_payments
ANALYTICS_DB=delidrone_analytics

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Service Ports ─────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
RESTAURANT_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
DRONE_SERVICE_PORT=3005
PAYMENT_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
ANALYTICS_SERVICE_PORT=3008

# ─── AWS ───────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=delidrone-media

# ─── SMS / OTP ─────────────────────────────────────
ESKIZ_EMAIL=your_eskiz_email
ESKIZ_PASSWORD=your_eskiz_password
OTP_EXPIRES_IN=300

# ─── Payment ───────────────────────────────────────
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret_key
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SECRET_KEY=your_click_secret_key

# ─── FCM Push Notifications ────────────────────────
FCM_SERVER_KEY=your_fcm_server_key

# ─── Maps ──────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=your_mapbox_token
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ─── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3004
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token
